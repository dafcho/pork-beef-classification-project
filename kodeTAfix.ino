// Fungsi penskalaan MinMaxScaler
void minmax_scale(double* input, int len) {
    for (int i = 0; i < len; i++) {
        input[i] = (input[i] - min_vals[i]) / (max_vals[i] - min_vals[i]);
    }
}

// Fungsi untuk leaky ReLU
void leaky_relu(double* data, int size, double alpha=0.1) {
    for (int i = 0; i < size; i++) {
        data[i] = data[i] > 0 ? data[i] : alpha * data[i];
    }
}

// Fungsi untuk Softmax
void softmax_with_scale(double* input, int len, double scale) {
    double max_val = input[0];
    for (int i = 1; i < len; i++) {
        if (input[i] > max_val) {
            max_val = input[i];
        }
    }
    double sum = 0;
    for (int i = 0; i < len; i++) {
        input[i] = exp((input[i] - max_val) * scale);
        sum += input[i];
    }
    for (int i = 0; i < len; i++) {
        input[i] /= sum;
    }
}

// Fungsi dense layer
void dense_layer(const double* input, const double* weights, const double* bias, double* output, int input_size, int output_size) {
    for (int j = 0; j < output_size; j++) {
        output[j] = bias[j];
        for (int i = 0; i < input_size; i++) {
            output[j] += input[i] * weights[i * output_size + j];
        }
    }
}

// Fungsi fitur polynomial
void compute_polynomial_features(const double *input, double *polyFeatures) {
    int index = 0;
    for (int i = 0; i < 6; i++) {
        polyFeatures[index++] = input[i];
    }
    for (int i = 0; i < 6; i++) {
        for (int j = i; j < 6; j++) {
            polyFeatures[index++] = input[i] * input[j];
        }
    }
}

// Fungsi untuk menerapkan BatchNormalization pada array output
void apply_batch_normalization(double* data, int size, 
                             const double* gamma, const double* beta,
                             const double* moving_mean, const double* moving_variance,
                             double epsilon = 1e-3) { // Keras biasanya menggunakan 1e-3
    for (int i = 0; i < size; i++) {
        double stddev = sqrt(moving_variance[i] + epsilon);
        data[i] = (data[i] - moving_mean[i]) / stddev;
        data[i] = data[i] * gamma[i] + beta[i];
    }
}

// Fungsi ANN 
void ann_predict(double* polyFeatures, double* output) {
    double output_hidden1[64];
    double output_hidden2[64];
    double output_hidden3[64];

    // --- Hidden Layer 1 ---
    dense_layer(polyFeatures, (const double*)weights_input_hidden1, bias_hidden1, output_hidden1, 27, 64);

    leaky_relu(output_hidden1, 64, 0.1);
    apply_batch_normalization(output_hidden1, 64, bn1_gamma, bn1_beta, bn1_mean, bn1_variance);

    // --- Hidden Layer 2 ---
    dense_layer(output_hidden1, (const double*)weights_hidden1_hidden2, bias_hidden2, output_hidden2, 64, 64);
    
    apply_batch_normalization(output_hidden2, 64, bn2_gamma, bn2_beta, bn2_mean, bn2_variance);
    leaky_relu(output_hidden2, 64, 0.1);

    // --- Hidden Layer 3 ---
    dense_layer(output_hidden2, (const double*)weights_hidden2_hidden3, bias_hidden3, output_hidden3, 64, 64);

    apply_batch_normalization(output_hidden3, 64, bn3_gamma, bn3_beta, bn3_mean, bn3_variance);
    leaky_relu(output_hidden3, 64, 0.1);


    // --- Output Layer ---
    dense_layer(output_hidden3, (const double*)weights_hidden3_output, bias_output, output, 64, 3);
    
    softmax_with_scale(output, 3, 1.0);
}

